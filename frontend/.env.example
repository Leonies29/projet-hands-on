# URL de base de l’API (sans slash final)
# En dev : laisser vide pour utiliser le proxy Vite /api → http://localhost:8080
# En prod (Cloud Run) : URL complète du service API, ex. https://mon-api-xxxxx.run.app
VITE_API_BASE_URL=

# true = données fictives (mockApi.js), idéal pour avancer sans backend. false = vrais appels HTTP.
VITE_USE_MOCK=false
