# Copier vers .env et remplir pour GCS + Vertex (Cloud Run / local avec compte de service)

# Vide = stockage local dans api/data/store.json (pratique pour commencer aujourd’hui)
GCS_BUCKET=
# Chemin du fichier dans le bucket, ex. data/lignes.json
GCS_OBJECT_PATH=data/store.json

# Projet GCP + région Vertex (ex. europe-west1) — optionnel tant que tu n’appelles pas Vertex
GCP_PROJECT=
VERTEX_LOCATION=europe-west1
